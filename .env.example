# Copia este archivo a .env y rellena tus valores.
# 1) OPENPROJECT_BASE_URL: la URL de tu OpenProject INCLUYENDO la subruta si aplica
#    (p. ej. https://tu-instancia.com/openproject). NO agregues /api/v3.
# 2) OPENPROJECT_TOKEN: Mi cuenta -> Tokens de acceso -> API -> generar.

OPENPROJECT_BASE_URL=https://TU-INSTANCIA/openproject
OPENPROJECT_TOKEN=PEGA_AQUI_TU_TOKEN
